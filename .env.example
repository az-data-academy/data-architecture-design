# Formation Data Lakehouse — Variables d'environnement
# Copier ce fichier en .env et ajuster si nécessaire

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000

# AWS (pointe vers MinIO)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# Polaris
POLARIS_URI=http://polaris:8181/api/catalog

# Nessie
NESSIE_URI=http://nessie:19120/api/v2

# Trino
TRINO_HOST=trino
TRINO_PORT=8080

# JupyterLab
JUPYTER_TOKEN=formation2024

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# Redis (online feature store)
REDIS_URL=redis://redis:6379

# Postgres CDC (démo formateur)
POSTGRES_HOST=postgres-demo
POSTGRES_PORT=5432
POSTGRES_DB=retailco
POSTGRES_USER=retailco
POSTGRES_PASSWORD=retailco
